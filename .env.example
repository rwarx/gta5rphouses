# ============================================================
# GTA5RP Apartment Checker — example environment configuration
# Copy this file to `.env` and adjust the values.
#   cp .env.example .env
# ============================================================

# ---------- Application ----------
APP_NAME=GTA5RP Apartment Checker
VERSION=1.0.0
# IANA timezone name used by the scheduler and Payday detection
TIMEZONE=Asia/Novosibirsk

# ---------- Telegram (required for bot & notifications) ----------
# Token from @BotFather. Leave empty to run without the Telegram bot.
BOT_TOKEN=
# Comma-separated list of admin Telegram user IDs allowed to use the bot.
ALLOWED_USER_IDS=

# ---------- Database ----------
# Async SQLAlchemy URL. Docker Compose uses PostgreSQL:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/apartment_checker
# For quick local development without PostgreSQL you can use SQLite instead:
# DATABASE_URL=sqlite+aiosqlite:///./data/test.db
# Sync URL (used by Alembic). Derived from DATABASE_URL automatically if empty.
DATABASE_SYNC_URL=
# Redis (optional cache/queue).
REDIS_URL=redis://redis:6379/0

# ---------- Scraper ----------
TARGET_URL=https://wiki.gta5rp.com/map
# Run the browser headless (true) or with a visible window (false).
HEADLESS=true
# Optional path to a persistent Playwright browser profile.
PLAYWRIGHT_PROFILE=
# Fixed check interval in seconds (used when SMART_MODE=false).
CHECK_INTERVAL=60
# Proxy configuration.
USE_PROXY=false
PROXY=
# Launch the browser scrape only when the /realestate catalog reports new data
# (its "Обновлено"/fetchedAtMs marker advanced), instead of on a blind timer.
# Needs a resolvable REALESTATE_SERVER. Fails open (scrapes) if the marker can't
# be read, so a source hiccup never causes a missed update.
MAP_UPDATE_GATE=true

# ---------- Smart Mode ----------
# Adaptive monitoring: rare checks off-peak, frequent checks around Payday.
SMART_MODE=true
# Seconds between checks outside the Payday window.
LOW_INTERVAL=600
# Seconds between checks inside the Payday window.
HIGH_INTERVAL=5
# Payday window (minute of the hour). Start on one hour, end on the next.
PAYDAY_START_MINUTE=56
PAYDAY_END_MINUTE=1

# ---------- RealEstate catalog source ----------
# Fetches the full /realestate catalog for one server over HTTP (no browser).
# Runs independently of, and alongside, the map scraper.
REALESTATE_ENABLED=false
# Server display name (see SERVER_ORDER in realestate_client.py).
REALESTATE_SERVER=Murrieta
# Seconds between catalog fetches.
REALESTATE_INTERVAL=300
# Notify when an occupied object disappears from the catalog (freed up).
REALESTATE_NOTIFY_FREED=true

# ---------- Crash detection ----------
CRASH_DETECTION_ENABLED=true
CRASH_DETECTION_THRESHOLD=0.8
CRASH_CHECK_INTERVAL=60

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000

# ---------- Logging ----------
LOG_LEVEL=INFO
